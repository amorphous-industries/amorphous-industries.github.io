---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Amorphous Industries" currentPage="about">
  <div class="flex flex-col sm:flex-row gap-4 w-full max-w-xl mx-auto">

    <div class="glass rounded-2xl p-7 flex-1 text-left">
      <p class="text-[11px] font-semibold text-white/30 uppercase tracking-[0.12em] mb-4">
        Organization
      </p>
      <h2 class="text-lg font-semibold text-white leading-snug mb-5">
        Amorphous Industries
      </h2>
      <a class="text-sm text-cyan-400 hover:text-cyan-300 no-underline font-medium transition-colors"
         href="https://github.com/amorphous-industries">
        GitHub →
      </a>
    </div>

    <div class="glass rounded-2xl p-7 flex-1 text-left">
      <p class="text-[11px] font-semibold text-white/30 uppercase tracking-[0.12em] mb-4">
        Founder
      </p>
      <h2 class="text-lg font-semibold text-white leading-snug mb-5">
        Brian Hannafious
      </h2>
      <div class="flex items-center gap-4">
        <a class="text-sm text-cyan-400 hover:text-cyan-300 no-underline font-medium transition-colors"
           href="https://github.com/xbrianh">
          GitHub →
        </a>
        <a class="text-sm text-cyan-400 hover:text-cyan-300 no-underline font-medium transition-colors"
           href="https://www.linkedin.com/in/brian-hannafious-99921734/">
          LinkedIn →
        </a>
      </div>
    </div>

  </div>
</BaseLayout>
