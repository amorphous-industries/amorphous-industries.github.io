---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Amorphous Industries" currentPage="about">
  <div class="flex flex-col sm:flex-row justify-center gap-6 mx-auto">

    <div class="bg-gray-100 text-gray-900 rounded-lg p-6 opacity-80 w-72">
      <h5 class="text-lg font-semibold">Amorphous Industries</h5>
      <h6 class="text-sm text-gray-500 mb-2">Organization</h6>
      <a class="text-cyan-500 hover:text-cyan-400" href="https://github.com/amorphous-industries">GitHub</a>
    </div>

    <div class="bg-gray-100 text-gray-900 rounded-lg p-6 opacity-80 w-72">
      <h5 class="text-lg font-semibold">Brian Hannafious</h5>
      <h6 class="text-sm text-gray-500 mb-2">Founder</h6>
      <a class="text-cyan-500 hover:text-cyan-400" href="https://github.com/xbrianh">GitHub</a>
      <a class="text-cyan-500 hover:text-cyan-400 ml-3" href="https://www.linkedin.com/in/brian-hannafious-99921734/">LinkedIn</a>
    </div>

  </div>
</BaseLayout>
