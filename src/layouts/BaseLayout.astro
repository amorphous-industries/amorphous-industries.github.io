---
import '../styles/global.css';

interface Props {
  title: string;
  currentPage: string;
  showWatermark?: boolean;
}

const { title, currentPage, showWatermark = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0b0c10] text-white font-sans antialiased min-h-screen">
    <div class="bg-site flex flex-col min-h-screen">

      <!-- Navigation -->
      <nav class="flex items-center justify-between px-8 py-6 max-w-5xl mx-auto w-full">
        <a href="/" class="flex items-center gap-2.5 text-white font-semibold text-base tracking-tight no-underline hover:text-white/80 transition-colors">
          <img
            src="/logo_no_text.png"
            alt=""
            aria-hidden="true"
            class="h-7 w-auto"
            style="filter: invert(1) sepia(1) saturate(4) hue-rotate(155deg) brightness(1.15); opacity: 0.85;"
          />
          Amorphous Industries
        </a>
        <div class="flex items-center gap-6">
          <a href="/"
             class:list={[
               'text-sm font-medium no-underline transition-colors',
               currentPage === 'home' ? 'text-white' : 'text-white/40 hover:text-white/70'
             ]}>
            Home
          </a>
          <a href="/about/"
             class:list={[
               'text-sm font-medium no-underline transition-colors',
               currentPage === 'about' ? 'text-white' : 'text-white/40 hover:text-white/70'
             ]}>
            About
          </a>
        </div>
      </nav>

      <!-- Main content -->
      <main class="flex-1 flex items-center justify-center px-8 py-12 relative">
        {showWatermark && (
          <img
            src="/logo_no_text.png"
            alt=""
            aria-hidden="true"
            class="logo-watermark"
          />
        )}
        <div class="relative z-10 w-full flex justify-center">
          <slot />
        </div>
      </main>

      <!-- Footer -->
      <footer class="flex justify-center items-center gap-5 py-8 max-w-5xl mx-auto w-full">
        <a href="https://amorphousindustries.slack.com"
           class="opacity-30 hover:opacity-70 transition-opacity">
          <img src="/slack_logo.svg" class="h-5" alt="Slack" />
        </a>
        <a href="mailto:info@amorphous-industries.com"
           class="opacity-30 hover:opacity-70 transition-opacity">
          <img src="/mail_icon.svg" class="h-5" alt="Email" />
        </a>
      </footer>

    </div>
  </body>
</html>
